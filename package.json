{
  "name": "glue-fumen",
  "version": "1.0.0",
  "license": "MIT",
  "description": "A npm package with CLI to glue/unglue fumens optimized for speed.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "glue-fumen": "./dist/glue.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:lib && npm run build:cli",
    "build:lib": "tsup src/index.ts --format esm --clean --dts --minify",
    "build:cli": "tsup src/glue.ts --format esm --minify",
    "dev": "tsup src/index.ts src/glue.ts --format esm --watch",
    "prepublishOnly": "npm run test && npm run build",
    "test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marfung37/GluingFumens.git"
  },
  "bugs": {
    "url": "https://github.com/Marfung37/GluingFumens/issues"
  },
  "dependencies": {
    "tetris-fumen": "^1.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.10",
    "@types/yargs": "^17.0.33",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "mitata": "^1.0.34",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "yargs": "^18.0.0"
  }
}
